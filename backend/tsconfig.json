{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["node"],
    "lib": ["ESNext"]
  },
  "include": ["src/**/*", "prisma/**/*"],
  "ts-node": {
    "files": true
  }
}
